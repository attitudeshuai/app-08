generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("STUDENT")
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions            Question[]
  papers               Paper[]
  paperTemplates       PaperTemplate[]
  exams                Exam[]
  examRecords          ExamRecord[]
  examSessions         ExamSession[]
  wrongQuestions       WrongQuestion[]
  examReservations     ExamReservation[]
  notifications        Notification[]
  questionHistory      QuestionHistory[]
  questionTags         QuestionTag[]
  favoriteQuestions    FavoriteQuestion[]
  monitorLogs          ExamMonitorLog[]
  questionDiscussions  QuestionDiscussion[]
  discussionLikes      QuestionDiscussionLike[]
}

model Question {
  id         Int      @id @default(autoincrement())
  type       String
  content    String
  options    Json?
  answer     String
  score      Float    @default(2)
  analysis   String?
  subject    String
  difficulty String   @default("MEDIUM")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdBy Int  @map("createdById")
  user      User @relation(fields: [createdBy], references: [id])

  paperItems         PaperItem[]
  paperTemplateItems PaperTemplateItem[]
  wrongQuestions     WrongQuestion[]
  history            QuestionHistory[]
  favoriteQuestions  FavoriteQuestion[]
  discussions        QuestionDiscussion[]
}

model QuestionHistory {
  id         Int      @id @default(autoincrement())
  questionId Int
  type       String
  content    String
  options    Json?
  answer     String
  score      Float    @default(2)
  analysis   String?
  subject    String
  difficulty String   @default("MEDIUM")
  version    Int
  remark     String?
  createdAt  DateTime @default(now())

  modifiedBy Int  @map("modifiedById")
  modifier   User @relation(fields: [modifiedBy], references: [id])

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, version])
  @@index([questionId])
  @@index([modifiedBy])
}

model Paper {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  totalScore  Float
  duration    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy Int  @map("createdById")
  user      User @relation(fields: [createdBy], references: [id])

  items PaperItem[]
  exams Exam[]
}

model PaperTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  totalScore  Float
  duration    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy Int  @map("createdById")
  user      User @relation(fields: [createdBy], references: [id])

  items PaperTemplateItem[]

  @@index([createdBy])
}

model PaperTemplateItem {
  id         Int   @id @default(autoincrement())
  sortOrder  Int
  score      Float
  questionId Int
  templateId Int

  question Question       @relation(fields: [questionId], references: [id])
  template PaperTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([questionId])
}

model PaperItem {
  id         Int   @id @default(autoincrement())
  sortOrder  Int
  score      Float
  questionId Int
  paperId    Int

  question Question @relation(fields: [questionId], references: [id])
  paper    Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([paperId])
  @@index([questionId])
}

model Exam {
  id          Int      @id @default(autoincrement())
  title       String
  startTime   DateTime
  endTime     DateTime
  status      String   @default("DRAFT")
  autoSubmit  Boolean  @default(true)
  monitorEnabled   Boolean  @default(true)
  maxTabSwitchCount Int    @default(10)
  maxIpChangeCount Int     @default(3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paperId    Int    @map("paperId")
  paper      Paper  @relation(fields: [paperId], references: [id])
  createdBy  Int    @map("createdById")
  user       User   @relation(fields: [createdBy], references: [id])

  examRecords      ExamRecord[]
  examSessions     ExamSession[]
  wrongQuestions   WrongQuestion[]
  examReservations ExamReservation[]
  monitorLogs      ExamMonitorLog[]
}

model ExamRecord {
  id             Int      @id @default(autoincrement())
  status         String   @default("NOT_STARTED")
  startTime      DateTime?
  submitTime     DateTime?
  totalScore     Float?
  answers        Json?
  totalActiveTime Int     @default(0)
  enterCount     Int      @default(0)
  isAutoSubmitted Boolean  @default(false)
  isSuspicious   Boolean  @default(false)
  suspiciousReasons Json?
  tabSwitchCount Int      @default(0)
  ipChangeCount  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  examId Int  @map("examId")
  exam   Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId Int  @map("userId")
  user   User @relation(fields: [userId], references: [id])

  wrongQuestions WrongQuestion[]
  sessions       ExamSession[]
  monitorLogs    ExamMonitorLog[]

  @@unique([examId, userId])
  @@index([examId])
  @@index([userId])
  @@index([isSuspicious])
}

model ExamSession {
  id         Int      @id @default(autoincrement())
  enterTime  DateTime
  exitTime   DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  examRecordId Int         @map("examRecordId")
  examRecord   ExamRecord  @relation(fields: [examRecordId], references: [id], onDelete: Cascade)
  examId       Int         @map("examId")
  exam         Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId       Int         @map("userId")
  user         User        @relation(fields: [userId], references: [id])

  @@index([examId])
  @@index([userId])
  @@index([examRecordId])
}

model ExamMonitorLog {
  id            Int      @id @default(autoincrement())
  type          String
  description   String?
  ipAddress     String?
  userAgent     String?
  extraData     Json?
  createdAt     DateTime @default(now())

  examId       Int        @map("examId")
  exam         Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId       Int        @map("userId")
  user         User       @relation(fields: [userId], references: [id])
  examRecordId Int        @map("examRecordId")
  examRecord   ExamRecord @relation(fields: [examRecordId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@index([userId])
  @@index([examRecordId])
  @@index([type])
  @@index([createdAt])
}

model WrongQuestion {
  id            Int      @id @default(autoincrement())
  userAnswer    String?
  correctAnswer String
  subject       String
  createdAt     DateTime @default(now())

  userId        Int        @map("userId")
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId    Int        @map("questionId")
  question      Question   @relation(fields: [questionId], references: [id])
  examId        Int        @map("examId")
  exam          Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  examRecordId  Int        @map("examRecordId")
  examRecord    ExamRecord @relation(fields: [examRecordId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@index([examId])
  @@index([subject])
}

model ExamReservation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examId Int  @map("examId")
  exam   Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  userId Int  @map("userId")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
  @@index([examId])
  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   @default("SYSTEM")
  isRead    Boolean  @default(false)
  relatedId Int?
  createdAt DateTime @default(now())

  userId Int  @map("userId")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

model QuestionTag {
  id        Int      @id @default(autoincrement())
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int  @map("userId")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  favoriteQuestions FavoriteQuestionTag[]

  @@unique([userId, name])
  @@index([userId])
}

model FavoriteQuestion {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId     Int      @map("userId")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId Int      @map("questionId")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  tags FavoriteQuestionTag[]

  @@unique([userId, questionId])
  @@index([userId])
  @@index([questionId])
}

model FavoriteQuestionTag {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  favoriteId Int              @map("favoriteId")
  favorite   FavoriteQuestion @relation(fields: [favoriteId], references: [id], onDelete: Cascade)
  tagId      Int              @map("tagId")
  tag        QuestionTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([favoriteId, tagId])
  @@index([favoriteId])
  @@index([tagId])
}

model QuestionDiscussion {
  id         Int      @id @default(autoincrement())
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  questionId Int      @map("questionId")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  userId     Int   @map("userId")
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId   Int?               @map("parentId")
  parent     QuestionDiscussion? @relation("DiscussionReplies", fields: [parentId], references: [id], onDelete: Cascade)

  replies    QuestionDiscussion[] @relation("DiscussionReplies")
  likes      QuestionDiscussionLike[]

  @@index([questionId])
  @@index([userId])
  @@index([parentId])
  @@index([createdAt])
}

model QuestionDiscussionLike {
  id           Int                @id @default(autoincrement())
  createdAt    DateTime           @default(now())

  discussionId Int                @map("discussionId")
  discussion   QuestionDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  userId       Int                @map("userId")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([discussionId, userId])
  @@index([discussionId])
  @@index([userId])
}
